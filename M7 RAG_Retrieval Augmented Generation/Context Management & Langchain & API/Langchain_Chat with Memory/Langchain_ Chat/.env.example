# =============================================================================
# LangChain Chat with Memory - Environment Configuration
# =============================================================================
# 
# IMPORTANT: 
# 1. Copy this file to .env
# 2. Fill in your actual credentials
# 3. NEVER commit .env to version control
# 4. Keep .env in .gitignore
#
# Get tokens from:
# - HuggingFace: https://huggingface.co/settings/tokens
# - OpenAI: https://platform.openai.com/api-keys
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED: HuggingFace API Token
# ─────────────────────────────────────────────────────────────────────────────
# This token is REQUIRED to use HuggingFace models
# Get it from: https://huggingface.co/settings/tokens
# Format: hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_TOKEN=hf_your_token_here_REQUIRED!

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL: LLM Model Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Model name to use (defaults to Qwen if not specified)
# Popular options:
# - Qwen/Qwen3-Coder-Next:novita (fast, good for Arabic)
# - meta-llama/Llama-2-7b-chat (large, powerful)
# - mistralai/Mistral-7B-Instruct-v0.2 (balanced)
# - google/flan-t5-large (lightweight)
#
HF_MODEL=Qwen/Qwen3-Coder-Next:novita

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL: LLM Behavior Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Temperature controls randomness (creativity):
# - 0.0 = deterministic (always same response)
# - 0.5 = balanced (recommended)
# - 1.0+ = very creative/random
TEMPERATURE=0.2

# Timeout for API requests (seconds)
TIMEOUT=60

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL: Logging Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────────
# Setup Instructions
# ─────────────────────────────────────────────────────────────────────────────
# 
# 1. Get HuggingFace token:
#    ```
#    - Go to: https://huggingface.co/settings/tokens
#    - Click "New token"
#    - Name it (e.g., "LangChain-Chat")
#    - Select "Read" access
#    - Copy the token (starts with hf_)
#    ```
#
# 2. Create .env file:
#    ```
#    cp .env.example .env
#    ```
#
# 3. Edit .env and paste your token:
#    ```
#    HF_TOKEN=hf_xxx...
#    ```
#
# 4. Verify it works:
#    ```
#    python -c "from dotenv import load_dotenv; import os; load_dotenv(); print(bool(os.getenv('HF_TOKEN')))"
#    ```
#    Should print: True
#
# ─────────────────────────────────────────────────────────────────────────────
